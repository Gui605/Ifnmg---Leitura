{
  "name": "ifnmg-leitura-backend",
  "version": "1.0.0",
  "description": "Backend modularizado em TypeScript e Prisma focado em desenvolvimento local nativo.",
  "main": "dist/server.js",
  "engines": {
    "node": "^20.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "start": "node dist/server.js",
    "dev": "nodemon --exec npx tsx src/server.ts",
    "build": "tsc",
    "postinstall": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate"
  },
  "keywords": [
    "typescript",
    "express",
    "prisma",
    "auth"
  ],
  "author": "Grupo",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.16",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.1",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "type": "commonjs",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
